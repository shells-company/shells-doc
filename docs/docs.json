{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "luma",
  "name": "My CLI Tool",
  "colors": {
    "primary": "#FFB700",
    "light": "#FFB700",
    "dark": "#4B0082"
  },
  "favicon": "/favicon.svg",
  "fonts": {
    "family": "Atkinson",
    "source": "/fonts/atkinson-regular.woff",
    "format": "woff",
    "weight": 400
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "href": "https://mintlify.com/docs",
          "icon": "book-open-cover"
        },
        {
          "anchor": "Blog",
          "href": "https://mintlify.com/blog",
          "icon": "newspaper"
        }
      ]
    },
    "tabs": [
      {
        "tab": "GuideS",
        "groups": [
          {
            "group": "Getting started",
            "public": true,
            "pages": [
              "index",
              "page",
              "ai-tools/deprecated-tool-2",
              "ai-tools/3",
              "ai-tools/4",
              "essentials/new-page"
            ]
          },
          {
            "group": "Customization",
            "hidden": true,
            "public": true,
            "pages": [
              "essentials/starter",
              "essentials/site-map"
            ]
          },
          {
            "group": "Writing content",
            "public": true,
            "pages": [
              "essentials/writing",
              "essentials/code",
              "essentials/code",
              "essentials/images",
              "essentials/reusable-snippets"
            ]
          },
          {
            "group": "AI tools",
            "public": true,
            "pages": [
              "ai-tools/cursor",
              "ai-tools/cc-retired",
              "ai-tools/windsurf"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "public": true,
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoint examples",
            "public": true,
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      },
      {
        "tab": "PrimeRL Deubgging",
        "groups": [
          {
            "group": "PrimeIndex",
            "public": true,
            "pages": [
              "prime-rl/index",
              "prime-rl/index2"
            ]
          }
        ]
      },
      {
        "tab": "Larger Poems",
        "pages": [
          "poems/overview.mdx",
          {
            "group": "frag",
            "pages": [
              "poems/fragments",
              "poems/fragments-two",
              "poems/fragments-three",
              "poems/fragments-four",
              "poems/fragments-last"
            ]
          },
          "poems/mirror",
          "poems/untitled-page",
          "poems/spring-cleaning",
          "poems/summer-drift",
          "poems/daily-todos",
          "poems/sarah",
          "poems/look-up"
        ]
      },
      {
        "tab": "TODOS",
        "pages": [
          {
            "group": "Benji",
            "pages": [
              "systems-design"
            ]
          },
          "todos/single-page-editing",
          {
            "group": "Daily",
            "pages": [
              "todos/may-11th",
              "todos/may-12th",
              "todos/may-13th",
              "todos/may-26th"
            ]
          },
          "todos/weekly-ships-may-11th"
        ]
      },
      {
        "tab": "Markdown",
        "pages": [
          "pause",
          "somehtin",
          "paused",
          "hault",
          "asdf",
          "some-page"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hi@mintlify.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/mintlify",
      "github": "https://github.com/mintlify",
      "linkedin": "https://linkedin.com/company/mintlify"
    }
  }
}
