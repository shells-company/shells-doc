{
  "openapi": "3.1.0",
  "info": {
    "title": "GrepDB API",
    "description": "A database for grepping — index files and run grep-like searches over them.",
    "license": {
      "name": "MIT"
    },
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "http://localhost:8080"
    }
  ],
  "paths": {
    "/api/index": {
      "post": {
        "tags": ["Index"],
        "summary": "Index a file into a dataset",
        "operationId": "index",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GrepIndexPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "File indexed successfully",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/api/search": {
      "post": {
        "tags": ["Search"],
        "summary": "Search indexed files",
        "description": "Run a search against indexed files in a dataset. By default the search uses `grep`, but you can override the executable with the optional `command` field to use any compatible search tool available on the server (for example, `rg` for ripgrep). The `flags` field accepts an arbitrary search string that is forwarded to the chosen command.",
        "operationId": "search",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GrepSearchPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Search results returned successfully",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/api/{dataset}/tags": {
      "get": {
        "tags": ["Search"],
        "summary": "List tags for a dataset",
        "operationId": "get_all_tags",
        "parameters": [
          {
            "name": "dataset",
            "in": "path",
            "description": "The UUID of the dataset",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Tags returned successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TagsResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "GrepIndexPayload": {
        "type": "object",
        "required": ["dataset", "filename", "file_payload", "tags"],
        "properties": {
          "dataset": {
            "type": "string",
            "format": "uuid",
            "description": "The UUID of the dataset to index into"
          },
          "file_payload": {
            "type": "string",
            "description": "The content of the file"
          },
          "filename": {
            "type": "string",
            "description": "The filename to store"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Tags for nested storage (for example, [\"private\", \"user_auth\"])"
          }
        }
      },
      "GrepSearchPayload": {
        "type": "object",
        "required": ["dataset", "flags", "folder_filter"],
        "properties": {
          "dataset": {
            "type": "string",
            "format": "uuid",
            "description": "The UUID of the dataset to search"
          },
          "flags": {
            "type": "string",
            "description": "An arbitrary search string passed to the search command. With the default `grep` command this is the flag list and pattern (for example, \"-r -n pattern\")."
          },
          "folder_filter": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Optional tag folders to restrict the search to (for example, [\"___private\", \"___user_auth\"]). Pass an empty array to search the whole dataset."
          },
          "command": {
            "type": "string",
            "description": "Optional. The search executable to run instead of the default `grep`. Use this to support any compatible search tool available on the server (for example, `rg`)."
          }
        }
      },
      "TagsResponse": {
        "type": "object",
        "required": ["tags"],
        "properties": {
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of available tags for the dataset"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Search",
      "description": "Search operations on indexed data"
    },
    {
      "name": "Index",
      "description": "Index new files into datasets"
    }
  ]
}
