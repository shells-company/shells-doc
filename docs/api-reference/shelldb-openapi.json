{
  "openapi": "3.1.0",
  "info": {
    "title": "GrepDB API",
    "description": "A database for grepping - search indexed content with grep-like functionality",
    "license": {
      "name": "MIT"
    },
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "http://localhost:8080"
    }
  ],
  "paths": {
    "/api/index": {
      "post": {
        "tags": [
          "Index"
        ],
        "operationId": "index",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GrepIndexPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "File indexed successfully",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/api/search": {
      "post": {
        "tags": [
          "Search"
        ],
        "operationId": "search",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GrepSearchPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Search results returned successfully",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/api/{dataset}/tags": {
      "get": {
        "tags": [
          "Search"
        ],
        "operationId": "get_all_tags",
        "parameters": [
          {
            "name": "dataset",
            "in": "path",
            "description": "The UUID of the dataset",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Tags returned successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TagsResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "GrepIndexPayload": {
        "type": "object",
        "required": [
          "dataset",
          "filename",
          "file_payload",
          "tags"
        ],
        "properties": {
          "dataset": {
            "type": "string",
            "format": "uuid",
            "description": "The UUID of the dataset to index into"
          },
          "file_payload": {
            "type": "string",
            "description": "The content of the file"
          },
          "filename": {
            "type": "string",
            "description": "The filename to store"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Tags for nested storage (e.g., [\"private\", \"user_auth\"])"
          }
        }
      },
      "GrepSearchPayload": {
        "type": "object",
        "required": [
          "dataset",
          "flags",
          "folder_filter"
        ],
        "properties": {
          "dataset": {
            "type": "string",
            "format": "uuid",
            "description": "The UUID of the dataset to search"
          },
          "flags": {
            "type": "string",
            "description": "Flags and search arguments to pass to the command (e.g., \"-r -n pattern\")"
          },
          "folder_filter": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Optional folders to filter the search (e.g., [\"___private\", \"___user_auth\"])"
          },
          "command": {
            "type": "string",
            "nullable": true,
            "description": "Shell command to run. Defaults to \"grep\" if omitted."
          }
        }
      },
      "TagsResponse": {
        "type": "object",
        "required": [
          "tags"
        ],
        "properties": {
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of available tags for the dataset"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Search",
      "description": "Search operations on indexed data"
    },
    {
      "name": "Index",
      "description": "Index new files into datasets"
    }
  ]
}